<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E2E">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="#181825">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✦ Ryzix Agent"
            android:textColor="#CDD6F4"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <ProgressBar
            android:id="@+id/agent_thinking_indicator"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone"/>

        <ImageButton
            android:id="@+id/agent_clear_btn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#6C7086"
            android:contentDescription="Clear conversation"/>
    </LinearLayout>

    <!-- Chat area -->
    <ScrollView
        android:id="@+id/agent_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <LinearLayout
            android:id="@+id/agent_chat_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp"/>
    </ScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#313244"/>

    <!-- Input row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:background="#181825">

        <EditText
            android:id="@+id/agent_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Ask Ryzix to code something…"
            android:hintTextColor="#6C7086"
            android:textColor="#CDD6F4"
            android:textSize="14sp"
            android:background="@null"
            android:padding="8dp"
            android:maxLines="4"
            android:imeOptions="actionSend"
            android:inputType="textMultiLine|textCapSentences"/>

        <ImageButton
            android:id="@+id/agent_send_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="@drawable/bg_send_button"
            android:tint="#1E1E2E"
            android:contentDescription="Send"/>
    </LinearLayout>
</LinearLayout>
